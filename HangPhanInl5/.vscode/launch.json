// 1. Låna ut en specifik bok till en viss person.
// Check an available book.
db.book.findOne({ _id: 2,
    "copies.status": "Available"
});
// Update books, copies status to be Loaned.
db.book.updateOne({ _id: 2,
    "copies.copyId": 2
},
{ $set: {
        "copies.status": "Loaned"
    }
});
// Update customer, add the loan to the loans array.
var loanDatum = new Date();
var dueDatum = new Date();
dueDatum.setDate(loanDatum.getDate() + 14);

db.customer.updateOne(
    { _id: 2
},
{
        $push: {
            loans: {
                bookId: 2,
                copyId: 2,
                loanDate: loanDatum,
                dueDate: dueDatum
        }
    }
}
)

// 2. Lämna tillbaka en specifik bok från en viss person.
// First, update copies in book status.
db.book.updateOne(
    { _id: 3,
    "copies.copyId": 3
},
{ $set: {
        "copies.status": "Available"
    }
}
)
// Then, remove the loan from the customer's loans array
bd.customer.updateOne(
    { _id: 3
},
{
        $pull: {
            loans: {
                bookId: 3,
                copyId: 3
        }
    }
}
)

